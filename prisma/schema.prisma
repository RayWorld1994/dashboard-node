generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Auth user — owns email/password for login
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// Dashboard team member (displayed in the UI, seeded with fake data)
model Profile {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  role      String
  avatarUrl String?
  createdAt DateTime @default(now())

  ownedProjects Project[]     @relation("ProjectOwner")
  assignedTasks Task[]        @relation("TaskAssignee")
  activityLogs  ActivityLog[]

  @@map("profiles")
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   // active | completed | pending
  ownerId   Int
  owner     Profile  @relation("ProjectOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())

  tasks     Task[]

  @@map("projects")
}

model Task {
  id         Int       @id @default(autoincrement())
  title      String
  status     String    // todo | in_progress | done
  priority   String    // low | medium | high
  projectId  Int
  project    Project   @relation(fields: [projectId], references: [id])
  assignedTo Int
  assignee   Profile   @relation("TaskAssignee", fields: [assignedTo], references: [id])
  dueDate    DateTime?
  createdAt  DateTime  @default(now())

  @@map("tasks")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       Profile  @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   Int
  createdAt  DateTime @default(now())

  @@map("activity_logs")
}
